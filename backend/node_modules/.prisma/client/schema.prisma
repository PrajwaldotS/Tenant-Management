generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  ADMIN
  MANAGER
  COLLECTOR
}

enum RentStatus {
  PENDING
  PARTIAL
  PAID
  OVERDUE
}

enum PaymentMethod {
  CASH
  UPI
  BANK
}

model User {
  id          String    @id @default(uuid())
  name        String
  email       String    @unique
  password    String
  role        Role
  isActive    Boolean   @default(true)
  lastLoginAt DateTime?

  // Relations
  ownedProperties   Property[] @relation("PropertyOwner")
  managedProperties Property[] @relation("PropertyManager")
  paymentsCreated   Payment[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([email])
  @@index([role])
}

model Property {
  id       String  @id @default(uuid())
  name     String
  address  String
  isActive Boolean @default(true)

  // Relations
  ownerId String
  owner   User   @relation("PropertyOwner", fields: [ownerId], references: [id])

  managerId String?
  manager   User?   @relation("PropertyManager", fields: [managerId], references: [id])

  tenants Tenant[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([ownerId])
  @@index([managerId])
  @@index([isActive])
}

model Tenant {
  id         String   @id @default(uuid())
  name       String
  phone      String
  moveInDate DateTime
  rentAmount Decimal  @default(0) @db.Decimal(10, 2)
  isActive   Boolean  @default(true)

  // Relations
  propertyId String
  property   Property @relation(fields: [propertyId], references: [id])

  rents    Rent[]
  payments Payment[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([propertyId])
  @@index([isActive])
}

model Rent {
  id             String     @id @default(uuid())
  amount         Decimal    @db.Decimal(10, 2)
  dueDate        DateTime
  status         RentStatus @default(PENDING)
  generatedMonth String // Format: YYYY-MM

  // Relations
  tenantId String
  tenant   Tenant @relation(fields: [tenantId], references: [id])

  payments Payment[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([tenantId, generatedMonth])
  @@index([tenantId])
  @@index([status])
  @@index([generatedMonth])
}

model Payment {
  id          String        @id @default(uuid())
  amount      Decimal       @db.Decimal(10, 2)
  paymentDate DateTime      @default(now())
  method      PaymentMethod
  referenceId String?

  // Relations
  tenantId String
  tenant   Tenant @relation(fields: [tenantId], references: [id])

  rentId String
  rent   Rent   @relation(fields: [rentId], references: [id])

  createdById String
  createdBy   User   @relation(fields: [createdById], references: [id])

  createdAt DateTime @default(now())

  @@index([tenantId])
  @@index([rentId])
  @@index([createdById])
  @@index([paymentDate])
}
